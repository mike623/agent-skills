default_platform(:ios)

# Replace placeholders before use:
# - <bundle id>
# - <app name>
# - <sku>

FLUTTER_DART_DEFINES = [
  # Add app-specific dart-defines here, for example:
  # "SUPABASE_URL=#{ENV['SUPABASE_URL']}",
].compact.map { |d| "--dart-define=#{d}" }.join(" ")

def app_identifier
  ENV["APP_IDENTIFIER"] || "<bundle id>"
end

def app_name
  ENV["APP_NAME"] || "<app name>"
end

def app_sku
  ENV["APP_SKU"] || "<sku>"
end

def apple_team_id
  ENV["APPLE_TEAM_ID"] || ENV["TEAM_ID"] || "<apple team id>"
end

def asc_api_key
  opts = {
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    in_house: false
  }
  if ENV["ASC_KEY_FILEPATH"].to_s.strip != ""
    opts[:key_filepath] = ENV["ASC_KEY_FILEPATH"]
  else
    opts[:key_content] = Base64.decode64(ENV.fetch("ASC_KEY_CONTENT"))
  end
  app_store_connect_api_key(**opts)
end

def clean_flutter_subprocess_env!
  %w[GEM_HOME GEM_PATH BUNDLE_GEMFILE BUNDLE_BIN_PATH RUBYOPT RUBYLIB].each { |k| ENV.delete(k) }
  ENV["PATH"] = "/opt/homebrew/bin:#{ENV['PATH']}" unless ENV["PATH"].to_s.include?("/opt/homebrew/bin")
end

def match_profile_name
  mapping = Actions.lane_context[SharedValues::MATCH_PROVISIONING_PROFILE_MAPPING] || {}
  mapping[app_identifier] || "match AppStore #{app_identifier}"
end

def ensure_ios_export_compliance_metadata!
  plist = "Runner/Info.plist"
  value = `/usr/libexec/PlistBuddy -c 'Print :ITSAppUsesNonExemptEncryption' #{plist} 2>/dev/null`.strip
  return if value == "false"

  sh("/usr/libexec/PlistBuddy -c 'Add :ITSAppUsesNonExemptEncryption bool false' #{plist} 2>/dev/null || /usr/libexec/PlistBuddy -c 'Set :ITSAppUsesNonExemptEncryption false' #{plist}")
  UI.message("Set ITSAppUsesNonExemptEncryption=false for standard HTTPS/TLS export compliance")
end

def install_signing_assets(api_key, readonly: true)
  # Local dev must not touch keychains: do not create, switch, unlock, delete,
  # reset, or pass explicit keychain settings. Temporary keychain setup belongs
  # only in CI=true-only lanes, never in local beta/build/release lanes.
  # App Store Connect API-key auth avoids Apple ID/2FA, but macOS codesigning
  # still requires the distribution private key to be available through the
  # existing macOS signing environment.
  match(type: "appstore", readonly: readonly, api_key: api_key, app_identifier: app_identifier)
end

platform :ios do
  desc "One-time: register bundle ID and report whether ASC app record exists"
  lane :bootstrap do
    app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: ENV["ASC_KEY_FILEPATH"],
      in_house: false
    )

    bundle = Spaceship::ConnectAPI::BundleId.all.detect { |b| b.identifier == app_identifier }
    if bundle.nil?
      Spaceship::ConnectAPI::BundleId.create(
        name: app_name.gsub(/[^0-9A-Za-z ]/, ""),
        identifier: app_identifier,
        platform: "IOS"
      )
      UI.success("Registered bundle id #{app_identifier}")
    else
      UI.message("Bundle id #{app_identifier} already registered")
    end

    app = Spaceship::ConnectAPI::App.find(app_identifier)
    if app.nil?
      UI.important("App Store Connect app record for #{app_identifier} does NOT exist yet.")
      UI.important("Create it once in App Store Connect → Apps → + with SKU #{app_sku}.")
    else
      UI.success("App Store Connect record for #{app_identifier} already exists")
    end
  end

  desc "One-time: create missing appstore provisioning profile in match repo"
  lane :certificates do
    api_key = asc_api_key
    match(type: "appstore", readonly: false, api_key: api_key, app_identifier: app_identifier)
  end

  desc "Sync signing assets read-only"
  lane :setup_signing do
    api_key = asc_api_key
    install_signing_assets(api_key)
  end

  desc "Build a signed App Store IPA without uploading"
  lane :build do
    api_key = asc_api_key
    install_signing_assets(api_key)
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Runner.xcodeproj",
      team_id: apple_team_id,
      code_sign_identity: "Apple Distribution",
      profile_name: match_profile_name,
      targets: ["Runner"]
    )
    ensure_ios_export_compliance_metadata!
    sh("cd ../.. && env -u GEM_HOME -u GEM_PATH -u BUNDLE_GEMFILE -u BUNDLE_BIN_PATH -u RUBYOPT flutter build ios --release --no-codesign #{FLUTTER_DART_DEFINES}")
    clean_flutter_subprocess_env!
    ipa = build_app(workspace: "Runner.xcworkspace", scheme: "Runner", export_method: "app-store")
    UI.success("Built signed IPA: #{ipa}")
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    api_key = asc_api_key
    install_signing_assets(api_key)
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Runner.xcodeproj",
      team_id: apple_team_id,
      code_sign_identity: "Apple Distribution",
      profile_name: match_profile_name,
      targets: ["Runner"]
    )

    begin
      latest = latest_testflight_build_number(api_key: api_key, app_identifier: app_identifier)
      increment_build_number(xcodeproj: "Runner.xcodeproj", build_number: latest + 1)
    rescue => e
      UI.important("Could not read TestFlight build number (#{e.message}); falling back to local increment.")
      increment_build_number(xcodeproj: "Runner.xcodeproj")
    end

    ensure_ios_export_compliance_metadata!
    sh("cd ../.. && env -u GEM_HOME -u GEM_PATH -u BUNDLE_GEMFILE -u BUNDLE_BIN_PATH -u RUBYOPT flutter build ios --release --no-codesign #{FLUTTER_DART_DEFINES}")
    clean_flutter_subprocess_env!
    ipa_path = build_app(workspace: "Runner.xcworkspace", scheme: "Runner", export_method: "app-store")
    upload_to_testflight(api_key: api_key, ipa: ipa_path, skip_waiting_for_build_processing: true)
  end

  desc "Upload/submit to App Store; run only when explicitly requested"
  lane :release do
    api_key = asc_api_key
    install_signing_assets(api_key)
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Runner.xcodeproj",
      team_id: apple_team_id,
      code_sign_identity: "Apple Distribution",
      profile_name: match_profile_name,
      targets: ["Runner"]
    )
    ensure_ios_export_compliance_metadata!
    sh("cd ../.. && env -u GEM_HOME -u GEM_PATH -u BUNDLE_GEMFILE -u BUNDLE_BIN_PATH -u RUBYOPT flutter build ios --release --no-codesign #{FLUTTER_DART_DEFINES}")
    clean_flutter_subprocess_env!
    ipa_path = build_app(workspace: "Runner.xcworkspace", scheme: "Runner", export_method: "app-store")
    upload_to_app_store(
      api_key: api_key,
      ipa: ipa_path,
      submit_for_review: true,
      automatic_release: false,
      skip_screenshots: true,
      force: true
    )
  end
end
