# Copy to ios/fastlane/.env and fill real values. NEVER commit real secrets.

# App identity
APP_IDENTIFIER=<bundle id>
APP_NAME=<app name>
APP_SKU=<sku>

# Apple team identifiers
APPLE_TEAM_ID=<apple team id>
TEAM_ID=<apple team id>
ITC_TEAM_ID=
APPLE_ID=

# App Store Connect API key
ASC_KEY_ID=
ASC_ISSUER_ID=
ASC_KEY_FILEPATH=
ASC_KEY_CONTENT=

# fastlane match signing store
MATCH_GIT_URL=<match git url>
MATCH_GIT_BRANCH=apple-team-<team id>
MATCH_TYPE=appstore
MATCH_READONLY=true
MATCH_PASSWORD=
